# Pinned Isaac Lab / Isaac Sim compatibility for spark_isaac_mycobot_v3.
# Source from host install scripts: source isaac_lab/versions.env
# Phase 8 residual RL uses Isaac Lab; Phases 0–6 do not require this at runtime.
#
# REVIEW: SPARK_ISAACLAB_BRANCH defaults to develop for local bootstrap only.
# Pin an exact tag/commit before claiming Phase 8 reproducibility.

# Isaac Sim 6.0 pre-built binary on DGX Spark (override if your install differs).
export SPARK_ISAAC_SIM_VERSION="${SPARK_ISAAC_SIM_VERSION:-6.0.0}"

# Isaac Lab branch/tag compatible with Isaac Sim 6.x (pre-built binary workflow).
export SPARK_ISAACLAB_REPO="${SPARK_ISAACLAB_REPO:-https://github.com/isaac-sim/IsaacLab.git}"
export SPARK_ISAACLAB_BRANCH="${SPARK_ISAACLAB_BRANCH:-develop}"

# Default clone location on the host (override with ISAACLAB_PATH).
export SPARK_ISAACLAB_PATH="${SPARK_ISAACLAB_PATH:-${HOME}/IsaacLab}"

# RL framework for Phase 8 residual training (override if standardized elsewhere).
export SPARK_ISAACLAB_RL_FRAMEWORK="${SPARK_ISAACLAB_RL_FRAMEWORK:-rsl_rl}"
